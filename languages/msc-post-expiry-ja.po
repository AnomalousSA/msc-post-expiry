msgid "Every 5 minutes"
msgstr "5分ごと"

#: msc-post-expiry.php:149
msgid "No expiry set"
msgstr "有効期限未設定"

#: msc-post-expiry.php:156
msgid "Expired"
msgstr "期限切れ"

